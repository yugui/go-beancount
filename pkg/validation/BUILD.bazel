load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "validation",
    srcs = [
        "account.go",
        "balance.go",
        "custom.go",
        "doc.go",
        "errors.go",
        "options.go",
        "order.go",
        "pad.go",
        "txn.go",
        "validation.go",
