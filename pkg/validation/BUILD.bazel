        "options_test.go",
        "order_test.go",
        "pad_test.go",
        "txn_test.go",
        "validation_options_test.go",
        "validation_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":validation"],
    deps = [
        "//pkg/ast",
        "@com_github_cockroachdb_apd_v3//:apd",
        "@com_github_google_go_cmp//cmp",
    ],
