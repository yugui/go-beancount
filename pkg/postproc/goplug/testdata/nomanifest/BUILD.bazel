load("@rules_go//go:def.bzl", "go_binary")
load("//pkg/postproc/goplug:fixture_constraints.bzl", "PLUGIN_COMPATIBLE_PLATFORMS")

# Plugin fixtures are hand-authored: they need linkmode=plugin, cgo=True,
# and a .so out name that gazelle's generator doesn't produce. Ignore
# keeps gazelle from rewriting the target into its standard shape.
# gazelle:ignore

go_binary(
    name = "nomanifest",
    srcs = ["plugin.go"],
    cgo = True,
    gotags = ["testhelpers"],
    linkmode = "plugin",
    out = "nomanifest.so",
    target_compatible_with = PLUGIN_COMPATIBLE_PLATFORMS,
    testonly = True,
    visibility = ["//pkg/postproc/goplug:__pkg__"],
)
